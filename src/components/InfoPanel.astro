---
const workItems = [
  {
    heading: 'Over a Decade in Blockchain Finance',
    date: 'Since 2013',
    body: "Managed a nine-figure multi-asset treasury for one of crypto's first multi-chain exchanges, settling $1B+ a month on-chain.",
  },
  {
    heading: 'Blockchain Finance to Core Development',
    date: 'Since 2016',
    body: "Core developer on a major proof-of-work EVM network. Client development, spec drafting and implementation, network organization and protocol upgrades. Shipping blockchain infrastructure and critical software.",
  },
  {
    heading: 'Building the Regulated Rail for Global Adoption',
    date: 'Since 2019',
    body: "Organized the launch of a GENIUS-compliant stablecoin on a neutral proof-of-work settlement rail — redeemable 1:1 through a licensed money transmitter — alongside the composable DeFi and regulated digital-asset primitives around it. Applying over a decade of industry knowledge to build long-term value where regulation lands and adoption multiplies.",
  },
  {
    heading: 'Early to the Next Delivery Model',
    date: 'Since 2024',
    body: "Now building with best practices in agentic tooling — optimizing for correctness and velocity, letting one person deliver at team pace and a lean team at organization scale. Shorter timelines, lower cost, no loss of rigor.",
  },
];

const howIWork = [
  {
    label: 'Architecture first',
    body: 'I see the whole system before I build it: phased, spec-driven, with explicit verification gates.',
  },
  {
    label: 'Phased, documented delivery',
    body: 'documented decisions and formal handoff at each stage, leading a small team or working independently.',
  },
  {
    label: 'Compliance built in',
    body: 'regulatory awareness and auditability from day one, not bolted on.',
  },
  {
    label: 'Agentic workflows',
    body: 'architecture stays central while agentic tooling handles the mechanical layers.',
  },
];

const contactRows = [
  { label: 'EMAIL', value: 'contact@christophermercer.org', href: 'mailto:contact@christophermercer.org' },
  { label: 'GITHUB', value: 'github.com/chris-mercer', href: 'https://github.com/chris-mercer' },
  { label: 'LINKEDIN', value: 'linkedin.com/in/c-mercer', href: 'https://linkedin.com/in/c-mercer' },
  { label: 'WHITEB0X', value: 'whiteb0x.com', href: 'https://whiteb0x.com' },
];
---

<div id="info-panel" class="info-panel" role="dialog" aria-modal="true" aria-labelledby="info-panel-title" hidden>
  <div class="info-panel-inner">
    <button id="info-panel-close" class="close-btn" type="button">CLOSE</button>

    <h1 id="info-panel-title" class="name">CHRISTOPHER MERCER</h1>
    <p class="title">Technical Blockchain Product &middot; Institutional Digital Assets</p>

    <section class="section">
      <p class="about-text">
        My work spans the full stack of blockchain integration, from the consensus layer to the
        regulated financial product. Drawn to distributed systems since Napster, working in
        blockchain since 2013 and building since 2016 — an open, results-driven builder
        motivated by the global adoption of distributed systems and the economic freedom they
        extend to people everywhere.
      </p>
    </section>

    <section class="section">
      <h2 class="section-title">DEVELOPMENT STUDIO</h2>
      <p class="portfolio-line">
        <a class="inline-link" href="https://whiteb0x.com" target="_blank" rel="noopener noreferrer">White B0x Inc.</a> is the development studio where I engineer and build the next products in blockchain.
      </p>
    </section>

    <section class="section">
      <h2 class="section-title">EXPERIENCE</h2>
      {workItems.map((item) => (
        <div class="work-item">
          <h3 class="work-heading">{item.heading}</h3>
          {item.date && <p class="work-date">{item.date}</p>}
          <p class="work-body">{item.body}</p>
        </div>
      ))}
    </section>

    <section class="section">
      <h2 class="section-title">METHOD</h2>
      {howIWork.map((item) => (
        <p class="how-line"><strong class="how-label">{item.label}</strong> — {item.body}</p>
      ))}
    </section>

    <section class="section">
      <h2 class="section-title">CONTACT</h2>
      <div class="contact-rows">
        {contactRows.map((row) => (
          <div class="contact-row">
            <span class="contact-label">{row.label}</span>
            <a class="contact-value" href={row.href} target={row.href.startsWith('http') ? '_blank' : undefined} rel={row.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
              {row.value}
            </a>
          </div>
        ))}
      </div>
    </section>

    {/* Hero model by Quaternius (https://poly.pizza/m/tQdzbZ1Cmw), CC0/public domain — no attribution required, kept here for reference only, not displayed. */}
    <a class="cta-btn" href="mailto:contact@christophermercer.org">Get in touch</a>
  </div>
</div>

<style>
  .info-panel {
    position: fixed;
    inset: 0;
    z-index: 20;
    background: var(--panel-bg);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    overflow-y: auto;
  }

  .info-panel[hidden] {
    display: none;
  }

  .info-panel-inner {
    max-width: 42rem;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
  }

  .close-btn {
    position: fixed;
    top: 1.5rem;
    right: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    background: var(--hud-chip-bg);
    border: 1px solid var(--border);
    padding: 0.5rem 0.75rem;
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .close-btn:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .name {
    font-size: clamp(1.5rem, 1.2rem + 1.5vw, 2.25rem);
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .title {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--text-secondary);
    text-transform: uppercase;
    margin-bottom: 2.5rem;
  }

  .section {
    margin-bottom: 2.5rem;
  }

  .section-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--accent-cyan);
    margin-bottom: 1.25rem;
  }

  .about-text,
  .work-body,
  .how-line,
  .portfolio-line {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .work-item {
    margin-bottom: 1.5rem;
  }

  .work-heading {
    font-size: 0.9375rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: var(--text);
    margin-bottom: 0.375rem;
  }

  .how-line {
    margin-bottom: 0.75rem;
  }

  .how-line:last-child {
    margin-bottom: 0;
  }

  .how-label {
    font-weight: 700;
    color: var(--text);
  }

  .work-date {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .portfolio-line {
    max-width: 34rem;
  }

  .contact-rows {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .contact-row {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 0.75rem;
    align-items: baseline;
  }

  .contact-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
  }

  .contact-value,
  .inline-link {
    color: var(--text);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .contact-value {
    font-size: 0.875rem;
  }

  .contact-value:hover,
  .inline-link:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .contact-value:focus-visible,
  .inline-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .cta-btn {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--bg);
    background: var(--accent);
    border: 1px solid var(--accent);
    padding: 0.625rem 1rem;
    cursor: pointer;
    transition: background-color 0.15s ease, border-color 0.15s ease;
  }

  .cta-btn:hover {
    background: var(--accent-cyan);
    border-color: var(--accent-cyan);
  }

  .cta-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>

<script>
  const panel = document.getElementById('info-panel') as HTMLDivElement;
  const trigger = document.getElementById('learn-more-trigger') as HTMLButtonElement;
  const closeBtn = document.getElementById('info-panel-close') as HTMLButtonElement;

  let lastFocused: HTMLElement | null = null;

  function openPanel() {
    lastFocused = document.activeElement as HTMLElement;
    panel.hidden = false;
    document.dispatchEvent(new CustomEvent('learnmore:open'));
    closeBtn.focus();
    document.addEventListener('keydown', onKeydown);
  }

  function closePanel() {
    panel.hidden = true;
    document.dispatchEvent(new CustomEvent('learnmore:close'));
    document.removeEventListener('keydown', onKeydown);
    lastFocused?.focus();
  }

  function onKeydown(e: KeyboardEvent) {
    if (e.key === 'Escape') closePanel();
  }

  trigger.addEventListener('click', openPanel);
  closeBtn.addEventListener('click', closePanel);
</script>
