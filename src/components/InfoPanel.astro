---
const workItems = [
  {
    heading: 'Over a Decade in Blockchain Finance',
    date: 'Career started in 2013',
    body: "Managed a nine-figure multi-asset treasury for one of crypto's first multi-chain exchanges, settling $1B+ a month on-chain.",
  },
  {
    heading: 'Blockchain Finance to Core Development',
    date: 'Development Journey',
    body: "Core developer on a major proof-of-work EVM network. Client development, spec drafting and implementation, network organization and protocol upgrades. Shipping blockchain infrastructure and critical software.",
  },
  {
    heading: 'Building the Regulated Rail for Global Adoption',
    date: 'Regulatory Friendly Development',
    body: "Organized the launch of a US-regulated stablecoin, redeemable 1:1 through a licensed money transmitter. Building composable DeFi and regulated digital-asset primitives. Applying industry knowledge and expertise to areas where long-term value accrues.",
  },
  {
    heading: 'Early to the Next Delivery Model',
    date: 'Modernized Workflow & Industry Leading Practices',
    body: "Always at the cutting edge of tech, now building with best practices in agentic tooling — optimizing correctness, increasing velocity, and allowing one person to deliver at team pace, one lean team to deliver at large-organization pace. Shrinking timelines and maximizing budgets.",
  },
];

const howIWork = [
  {
    label: 'Architecture first',
    body: 'I see the whole system before I build it: every initiative decomposed into phases, with explicit scope and verification gates. Research informed, spec driven development.',
  },
  {
    label: 'Phased, documented delivery',
    body: 'Delivered in phases with documented decisions and formal handoff at each stage, whether leading a small team or working independently.',
  },
  {
    label: 'Compliance built in',
    body: 'Regulatory awareness and auditability are built into the process from day one, not bolted on afterward.',
  },
  {
    label: 'Agentic Workflows',
    body: 'Best practices in agentic development run through every phase: architecture stays central while agentic tooling optimizes velocity on the mechanical layers around it.',
  },
];

const contactRows = [
  { label: 'EMAIL', value: 'contact@christophermercer.org', href: 'mailto:contact@christophermercer.org' },
  { label: 'GITHUB', value: 'github.com/chris-mercer', href: 'https://github.com/chris-mercer' },
  { label: 'LINKEDIN', value: 'linkedin.com/in/c-mercer', href: 'https://linkedin.com/in/c-mercer' },
  { label: 'WHITEB0X', value: 'whiteb0x.com', href: 'https://whiteb0x.com' },
];
---

<div id="info-panel" class="info-panel" role="dialog" aria-modal="true" aria-labelledby="info-panel-title" hidden>
  <div class="info-panel-inner">
    <button id="info-panel-close" class="close-btn" type="button">CLOSE</button>

    <h1 id="info-panel-title" class="name">CHRISTOPHER MERCER</h1>
    <p class="title">Technical Blockchain Product &middot; Institutional Digital Assets</p>

    <section class="section">
      <p class="about-text">
        I own blockchain integration end to end — from the consensus layer to the regulated
        financial product. Building since 2013, out of a traditional-finance background.
      </p>
    </section>

    <section class="section">
      <h2 class="section-title">SELECTED WORK</h2>
      {workItems.map((item) => (
        <div class="work-item">
          <h3 class="work-heading">{item.heading}</h3>
          {item.date && <p class="work-date">{item.date}</p>}
          <p class="work-body">{item.body}</p>
        </div>
      ))}
      <p class="supporting-line">
        Also: founded a composable DeFi stack and many application layer products.
      </p>
    </section>

    <section class="section">
      <h2 class="section-title">HOW I WORK</h2>
      {howIWork.map((item) => (
        <div class="how-item">
          <h3 class="how-label">{item.label}</h3>
          <p class="how-body">{item.body}</p>
        </div>
      ))}
    </section>

    <section class="section">
      <h2 class="section-title">CONTACT</h2>
      <div class="contact-rows">
        {contactRows.map((row) => (
          <div class="contact-row">
            <span class="contact-label">{row.label}</span>
            <a class="contact-value" href={row.href} target={row.href.startsWith('http') ? '_blank' : undefined} rel={row.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
              {row.value}
            </a>
          </div>
        ))}
      </div>
    </section>

    {/* Hero model by Quaternius (https://poly.pizza/m/tQdzbZ1Cmw), CC0/public domain — no attribution required, kept here for reference only, not displayed. */}
    <button class="close-btn-bottom" type="button" data-close>CLOSE</button>
  </div>
</div>

<style>
  .info-panel {
    position: fixed;
    inset: 0;
    z-index: 20;
    background: var(--panel-bg);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    overflow-y: auto;
  }

  .info-panel[hidden] {
    display: none;
  }

  .info-panel-inner {
    max-width: 42rem;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
  }

  .close-btn {
    position: fixed;
    top: 1.5rem;
    right: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    background: var(--hud-chip-bg);
    border: 1px solid var(--border);
    padding: 0.5rem 0.75rem;
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .close-btn:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .name {
    font-size: clamp(1.5rem, 1.2rem + 1.5vw, 2.25rem);
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--text);
    margin-bottom: 0.5rem;
  }

  .title {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--text-secondary);
    text-transform: uppercase;
    margin-bottom: 2.5rem;
  }

  .section {
    margin-bottom: 2.5rem;
  }

  .section-title {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--accent-cyan);
    margin-bottom: 1.25rem;
  }

  .about-text,
  .work-body,
  .how-body,
  .supporting-line {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--text-secondary);
  }

  .work-item,
  .how-item {
    margin-bottom: 1.5rem;
  }

  .work-heading,
  .how-label {
    font-size: 0.9375rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: var(--text);
    margin-bottom: 0.375rem;
  }

  .work-date {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .supporting-line {
    margin-top: 1.5rem;
    max-width: 34rem;
  }

  .contact-rows {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .contact-row {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 0.75rem;
    align-items: baseline;
  }

  .contact-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
  }

  .contact-value {
    font-size: 0.875rem;
    color: var(--text);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .contact-value:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .contact-value:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .close-btn-bottom {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    background: transparent;
    border: 1px solid var(--border);
    padding: 0.5rem 0.75rem;
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .close-btn-bottom:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
</style>

<script>
  const panel = document.getElementById('info-panel') as HTMLDivElement;
  const trigger = document.getElementById('learn-more-trigger') as HTMLButtonElement;
  const closeBtn = document.getElementById('info-panel-close') as HTMLButtonElement;
  const closeBtnBottom = document.querySelector('[data-close]') as HTMLButtonElement;

  let lastFocused: HTMLElement | null = null;

  function openPanel() {
    lastFocused = document.activeElement as HTMLElement;
    panel.hidden = false;
    document.dispatchEvent(new CustomEvent('learnmore:open'));
    closeBtn.focus();
    document.addEventListener('keydown', onKeydown);
  }

  function closePanel() {
    panel.hidden = true;
    document.dispatchEvent(new CustomEvent('learnmore:close'));
    document.removeEventListener('keydown', onKeydown);
    lastFocused?.focus();
  }

  function onKeydown(e: KeyboardEvent) {
    if (e.key === 'Escape') closePanel();
  }

  trigger.addEventListener('click', openPanel);
  closeBtn.addEventListener('click', closePanel);
  closeBtnBottom?.addEventListener('click', closePanel);
</script>
