---
import ElkScene from './ElkScene.tsx';
---

<div id="hero-canvas-wrap" aria-hidden="true">
  <ElkScene client:only="react" />
</div>

<style>
  #hero-canvas-wrap {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: #05070d;
  }

  #hero-canvas-wrap :global(canvas) {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
