---
---

<canvas id="hero-canvas" aria-hidden="true"></canvas>
<div id="hero-fallback" aria-hidden="true" hidden></div>

<style>
  #hero-canvas {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    display: block;
    width: 100%;
    height: 100%;
  }

  #hero-fallback {
    position: fixed;
    inset: 0;
    z-index: 0;
    background: radial-gradient(circle at 30% 40%, #3a1f5c, #08050c 70%);
  }
</style>

<script>
  import { initScene } from '../scripts/scene.js';

  const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
  const fallback = document.getElementById('hero-fallback') as HTMLDivElement;

  const sceneControls = initScene(canvas, fallback);

  document.addEventListener('learnmore:open', () => sceneControls.pause());
  document.addEventListener('learnmore:close', () => sceneControls.resume());
</script>
