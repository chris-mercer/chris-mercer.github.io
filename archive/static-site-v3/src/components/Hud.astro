---

<div class="hud">
  <div class="hud-corner top-left">
    <span class="wordmark">CHRISTOPHER MERCER</span>
    <button id="learn-more-trigger" class="learn-more" type="button" aria-haspopup="dialog" aria-controls="info-panel">
      LEARN MORE
    </button>
  </div>
  <div class="hud-corner top-right">
    <span class="tag">BUILDING SINCE 2013</span>
  </div>
</div>

<style>
  .hud {
    position: fixed;
    inset: 0;
    z-index: 10;
    pointer-events: none;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .hud-corner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    pointer-events: none;
  }

  .top-left {
    align-self: flex-start;
  }

  .top-right {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
  }

  .wordmark,
  .tag {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--text);
    background: var(--hud-chip-bg);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
  }

  .tag {
    color: var(--text-secondary);
  }

  .learn-more {
    pointer-events: auto;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--accent-cyan);
    background: var(--hud-chip-bg);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    border: 1px solid var(--border);
    padding: 0.5rem 0.75rem;
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .learn-more:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .learn-more:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  @media (max-width: 560px) {
    .wordmark {
      display: none;
    }
    .top-right {
      display: none;
    }
  }
</style>

<script>
  const learnMoreTrigger = document.getElementById('learn-more-trigger') as HTMLButtonElement;
  learnMoreTrigger.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('learnmore:open'));
  });
</script>
